#!/bin/bash
# grackle - Simple web server management for the people!
# More info at https://github.com/HumphreyBoaGart/grackle

### All script functions are thrown in a simple case statement
case $1 in

### Script documentation with 'grinstall help'
help | -h | --help)
exec cat <<EOF
  ▄▄ • ▄▄▄   ▄▄▄·  ▄▄· ▄ •▄ ▄▄▌  ▄▄▄ .
 ▐█ ▀ ▪▀▄ █·▐█ ▀█ ▐█ ▌▪█▌▄▌▪██•  ▀▄.▀·
 ▄█ ▀█▄▐▀▀▄ ▄█▀▀█ ██ ▄▄▐▀▀▄·██▪  ▐▀▀▪▄
 ▐█▄▪▐█▐█•█▌▐█ ▪▐▌▐███▌▐█.█▌▐█▌▐▌▐█▄▄▌
 ·▀▀▀▀ .▀  ▀ ▀  ▀ ·▀▀▀ ·▀  ▀.▀▀▀  ▀▀▀ 
 $(tput setaf 4 bold)INSTALLER UTILITY:$(tput sgr0)

  $(tput setaf 3 bold)To install Grackle base components w/ Nginx:$(tput sgr0)
    $(tput setaf 6)sudo grinstall web$(tput sgr0)

  $(tput setaf 3 bold)To install Grackle and all optional components:$(tput sgr0)
    $(tput setaf 6)sudo grinstall full$(tput sgr0)

  $(tput setaf 3 bold)To install Grackle components a la carte:$(tput sgr0)
    $(tput bold)Base:$(tput sgr0) $(tput setaf 6)sudo grinstall base$(tput sgr0)
    $(tput bold)Docker:$(tput sgr0) $(tput setaf 6)sudo grinstall docker$(tput sgr0)
    $(tput bold)Nginx:$(tput sgr0) $(tput setaf 6)sudo grinstall nginx$(tput sgr0)
    $(tput bold)PHP:$(tput sgr0) $(tput setaf 6)sudo grinstall php$(tput sgr0)

  $(tput setaf 3 bold)Full documentation index:$(tput sgr0)
    $(tput setaf 6)grackle help$(tput sgr0)

EOF
;;

### Base install with 'grinstall base'
base)

  # Create usergroups
  sudo groupadd admin
  sudo groupadd user
  sudo groupadd app

  # Clean up homedir permissions
  sudo chown -vR root:root /home/grackle
  sudo chmod -vR u+rwX,g-rwx,o-rwx /home/grackle
  sudo chmod -v u=rwx,g=rx,o=rx /home/grackle /home/grackle/bin /home/grackle/bin/shortcuts
  sudo chmod -v u=rwx,g=rx /home/grackle/bin/grackle /home/grackle/bin/grapp /home/grackle/bin/gruser
  sudo chgrp -v admin /home/grackle/bin/grackle /home/grackle/bin/grapp /home/grackle/bin/gruser
  sudo chmod -vR g+rX,o+rX /home/grackle/errors /home/grackle/void /home/grackle/bin/README.md
  sudo chmod -vR g+r,o+r /home/grackle/bin/grapp.md /home/grackle/bin/grinstall.md /home/grackle/bin/gruser.md

  # Configure apt
  sudo cp -b /home/grackle/skel/etc/apt/sources.list /etc/apt/sources.list
  sudo cp -b /home/grackle/skel/etc/apt/sources.list.d/debian.list /etc/apt/sources.list.d/debian.list
  sudo chmod -vR u+rwX,g+rX,o+rX /etc/apt/
  sudo apt update

  # Install additional packages
  sudo apt purge -y ntp
  sudo apt install -y apt-transport-https btop chrony git htop imagemagick ranger logrotate rsyslog ufw wget
  sudo apt install -y -t bookworm-backports curl tmux
  sudo systemctl enable chrony
  sudo systemctl enable ufw

  # Configure firewall
  sudo ufw reset
  sudo ufw default deny incoming
  sudo ufw default deny outgoing
  sudo ufw allow 22/tcp
  sudo ufw allow out 22/tcp
  sudo ufw allow out 53/tcp
  sudo ufw allow out 53/udp
  sudo ufw allow out 80/tcp
  sudo ufw allow out 123/udp
  sudo ufw allow out 443/tcp
  sudo ufw enable

  # Configure syslog
  sudo cp -R /home/grackle/skel/etc/syslog/boycottjournald.conf /etc/systemd/journald.conf.d/boycottjournald.conf
  sudo rm -v /etc/rsyslog.conf /etc/rsyslog.d/20-ufw.conf
  sudo cp /home/grackle/skel/etc/syslog/rsyslog.conf /etc/rsyslog.conf
  sudo cp /home/grackle/skel/etc/syslog/rsyslog.d/20-ufw.conf /etc/rsyslog.d/20-ufw.conf
  sudo cp /home/grackle/skel/etc/syslog/rsyslog.d/94-journald.conf /etc/rsyslog.d/94-journald.conf
  sudo systemctl enable rsyslog
  sudo systemctl restart rsyslog
  sudo systemctl restart systemd-journald
  sudo rm -rfv /var/log/journal

  # Additional configuration
  sudo rm -v /etc/adduser.conf
  sudo cp /home/grackle/skel/etc/adduser.conf /etc/adduser.conf
  sudo useradd -D -s /sbin/nologin

  # Close installer
;;

### Nginx install with 'grinstall nginx'
nginx)

  # Update firewall rules
  sudo ufw allow 80/tcp
  sudo ufw allow 443/tcp
  sudo ufw reload

  # Close installer
;;

### PHP install with 'grinstall php'
php)

  # Configure syslog
  sudo cp /home/grackle/skel/etc/syslog/rsyslog.d/30-phpfpm.conf /etc/rsyslog.d/30-phpfpm.conf

  # Close installer
;;

### Docker install with 'grinstall docker'
docker)
  # Close installer
;;

### Basic web server install with 'grinstall web'
web)
  sudo bash /home/grackle/bin/grinstall base
  sudo bash /home/grackle/bin/grinstall nginx
;;

### Full suite install with 'grinstall full'
full)
  sudo bash /home/grackle/bin/grinstall web
  sudo bash /home/grackle/bin/grinstall php
  sudo bash /home/grackle/bin/grinstall docker
;;

### Update Grackle with 'grinstall update'
update)

  # Delete old homedir contents and resync to repo
  sudo rm -rfv /home/grackle
  sudo git clone https://github.com/HumphreyBoaGart/grackle /home/grackle

  # Clean up homedir permissions
  sudo chown -vR root:root /home/grackle
  sudo chmod -vR u+rwX,g-rwx,o-rwx /home/grackle
  sudo chmod -v u=rwx,g=rx,o=rx /home/grackle /home/grackle/bin /home/grackle/bin/shortcuts
  sudo chmod -v u=rwx,g=rx /home/grackle/bin/grackle /home/grackle/bin/grapp /home/grackle/bin/gruser
  sudo chmod -v u=rwx /home/grackle/bin/grinstall
  sudo chgrp -v admin /home/grackle/bin/grackle /home/grackle/bin/grapp /home/grackle/bin/gruser
  sudo chmod -vR g+rX,o+rX /home/grackle/errors /home/grackle/void /home/grackle/bin/README.md
  sudo chmod -vR g+r,o+r /home/grackle/bin/grapp.md /home/grackle/bin/grinstall.md /home/grackle/bin/gruser.md

  # Close updater
;;

### Output error for any input not explicitly defined
*)
exec cat <<EOF

  $(tput setaf 1 bold)GRACKLE INSTALLER ERROR: No valid install mode specified!$(tput sgr0)

   Run $(tput setaf 6 bold)grinstall help$(tput sgr0) for a full list of Installer options.

EOF
;;

### Close initial case statement and move on with our life
esac
