/var/log/sys.log {
	rotate 4
	weekly
	compress
	delaycompress
	missingok
	notifempty
	create 640 root adm
	sharedscripts
	postrotate
		/usr/lib/rsyslog/rsyslog-rotate
	endscript
}
/var/log/auth.log
/var/log/cron.log
/var/log/kern.log
/var/log/mail.log
